main:
  // 3+ NamedArguments: always broken, even when the flat form fits.
  service
      --a=1
      --b=2
      --c=3
      --d=4

  // 2 NamedArguments: still flat when fits.
  service --a=1 --b=2

  // Wrapper: same threshold applies via emit_stmt_flat's walk.
  result := service
      --a=1
      --b=2
      --c=3
      --d=4

service --a --b --c=0 --d=0:
  return null
