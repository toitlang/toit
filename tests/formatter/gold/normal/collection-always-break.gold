main:
  // 5+ elements: always broken.
  items := [
    1,
    2,
    3,
    4,
    5,
  ]
  // 5-entry Map: broken per entry.
  config := {
    "a": 1,
    "b": 2,
    "c": 3,
    "d": 4,
    "e": 5,
  }
  // 5-element Set: broken.
  set := {
    1,
    2,
    3,
    4,
    5,
  }
  // Return wrapper works the same way.
  r := pick_one
  return [
    10,
    20,
    30,
    40,
    50,
  ]

main2:
  // 4 elements: still flat when it fits.
  a := [1, 2, 3, 4]
  b := {"x": 1, "y": 2}
  c := {10, 20}
  d := [1, 2]
  return [a, b, c]

pick_one := 0
